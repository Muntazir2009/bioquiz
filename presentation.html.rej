 .reveal-badge-inner{
   display:flex;align-items:center;gap:10px;background:rgba(0,0,0,.85);
   border:1px solid var(--border2);padding:12px 20px;border-radius:4px;
   backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px);
   animation:revealPulse 2s ease-in-out infinite;
 }
 @keyframes revealPulse{
   0%,100%{box-shadow:0 0 0 0 rgba(255,255,255,.1)}
   50%{box-shadow:0 0 0 8px rgba(255,255,255,0)}
 }
 .hormuz-card .reveal-badge-inner{
   border-color:rgba(212,160,23,.5);
   animation:revealPulseGold 2s ease-in-out infinite;
 }
 @keyframes revealPulseGold{
   0%,100%{box-shadow:0 0 0 0 rgba(212,160,23,.2)}
   50%{box-shadow:0 0 0 8px rgba(212,160,23,0)}
 }
 .reveal-badge-inner svg{width:16px;height:16px;stroke:var(--white);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
 .reveal-badge-inner span{font-family:var(--font);font-size:.48rem;letter-spacing:.2em;font-weight:900;color:var(--white)}
 
-.content-body{font-family:var(--body);font-size:clamp(.78rem,1.3vw,.92rem);line-height:1.7;color:var(--off);transition:filter .3s}
+.content-body{font-family:var(--body);font-size:clamp(1.05rem,1.75vw,1.42rem);line-height:1.65;color:var(--off);transition:filter .3s}
 .content-body b{color:var(--white);font-weight:700}
 .content-body ul,.content-body ol{padding-left:1.4em;margin:8px 0}
 .content-body li{margin-bottom:5px}
 .hormuz-card .content-body b{color:var(--gold)}
 
