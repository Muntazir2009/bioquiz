-.hormuz-dots .dot.on{background:var(--gold);border-color:var(--gold)}
+#autoBtn.on{background:var(--white);color:#000;border-color:var(--white)}
+#autoBtn.on:hover{background:var(--off);color:#000}
 
 /* ══════════════════════════════════
    OVERVIEW OVERLAY
 ══════════════════════════════════ */
 .ov-overlay{position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.96);display:none;flex-direction:column}
 .ov-overlay.open{display:flex;animation:fadeIn .2s ease}
 @keyframes fadeIn{from{opacity:0}to{opacity:1}}
 .ov-head{
   display:flex;align-items:center;justify-content:space-between;
   padding:0 clamp(14px,4vw,48px);height:54px;border-bottom:1px solid var(--border);flex-shrink:0;
 }
 .ov-title{font-family:var(--font);font-size:.58rem;font-weight:900;letter-spacing:.24em;color:var(--white)}
 .ov-close{
   display:flex;align-items:center;gap:5px;cursor:pointer;
   font-family:var(--font);font-size:.44rem;letter-spacing:.12em;font-weight:900;
   background:none;border:1px solid var(--border);padding:5px 12px;color:var(--muted);transition:all .15s;
 }
 .ov-close:hover{color:var(--white);border-color:var(--border2)}
 .ov-close svg{width:10px;height:10px;stroke:currentColor;fill:none;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round}
 .ov-grid{flex:1;overflow-y:auto;padding:18px clamp(14px,4vw,48px);display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:2px;align-content:start}
 .ov-card{background:var(--dark2);border:1px solid transparent;padding:14px 16px;cursor:pointer;transition:all .15s;border-left:2px solid transparent}
 .ov-card:hover,.ov-card.cur{background:var(--dark3);border-color:var(--border);border-left-color:var(--white)}
 .ov-num{font-family:var(--font);font-size:.36rem;letter-spacing:.16em;font-weight:900;color:rgba(255,255,255,.25);margin-bottom:5px}
 .ov-heading{font-family:var(--font);font-size:.62rem;font-weight:900;color:var(--white);line-height:1.2}
 
 @keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
 
 @media(max-width:680px){
   .slide-layout.has-diagram{grid-template-columns:1fr}
   .diagram-panel{position:static}
   .f-row{grid-template-columns:1fr}
   .pinned-inner{grid-template-columns:1fr}
   .pinned-arr{display:none}
 }
 @media(max-width:480px){
-  .dot-row{max-width:130px}
-  .nav-btn{padding:8px 12px;font-size:.42rem}
+  .sb-btn{padding:8px 12px;font-size:.42rem}
 }
 
 /* ══════════════════════════════════
    FULLSCREEN — CSS-based, works everywhere
 ══════════════════════════════════ */
 #pg-slides.fs-mode,#pg-thanks.fs-mode{
   position:fixed!important;inset:0!important;z-index:9000!important;
   width:100vw!important;height:100dvh!important;
   display:flex!important;flex-direction:column!important;
   background:#000!important;overflow:hidden!important;
 }
 body.fs-body{overflow:hidden!important}
 
 /* ══════════════════════════════════
    SLIDE DIRECTIONAL ANIMATIONS (swipe)
 ══════════════════════════════════ */
 @keyframes slideFromRight{
   from{opacity:0;transform:translateX(60px) scale(.98)}
   to{opacity:1;transform:translateX(0) scale(1)}
 }
 @keyframes slideFromLeft{
   from{opacity:0;transform:translateX(-60px) scale(.98)}
   to{opacity:1;transform:translateX(0) scale(1)}
 }
 @keyframes slideIn{
   from{opacity:0;transform:translateX(24px)}
   to{opacity:1;transform:translateX(0)}
 }
 .slide.active{display:block}
 .slide.dir-next{animation:slideFromRight .4s cubic-bezier(.16,1,.3,1) both}
 .slide.dir-prev{animation:slideFromLeft .4s cubic-bezier(.16,1,.3,1) both}
 
 /* Content stagger animation */
 .slide.active .content-card{animation:cardFadeIn .5s cubic-bezier(.16,1,.3,1) both}
 .slide.active .content-card:nth-child(1){animation-delay:.1s}
 .slide.active .content-card:nth-child(2){animation-delay:.2s}
 .slide.active .content-card:nth-child(3){animation-delay:.3s}
 @keyframes cardFadeIn{
   from{opacity:0;transform:translateY(16px)}
   to{opacity:1;transform:translateY(0)}
 }
 
 /* ══════════════════════════════════
    FIX ALL ARROW SVGS
 ══════════════════════════════════ */
-.nav-btn svg,.sb-btn svg,.tb-btn svg,.ov-close svg,.gen-back svg{
+.sb-btn svg,.tb-btn svg,.ov-close svg,.gen-back svg{
   width:11px!important;height:11px!important;flex-shrink:0;pointer-events:none;
 }
 
 /* ═══════════���══════════════════════
    STRAIT OF HORMUZ — special editorial typography
 ══════════════════════════════════ */
 .hormuz-brand{display:flex;flex-direction:column;gap:2px}
 .hormuz-strait-of{
   font-family:Georgia,'Times New Roman',serif;
   font-size:clamp(.65rem,1.4vw,.9rem);
   font-weight:400;font-style:italic;
   letter-spacing:.45em;
   color:rgba(255,255,255,.45);
   text-transform:uppercase;
   line-height:1;
 }
 .hormuz-word{
   font-family:'Arial Black',Arial,sans-serif;
   font-size:clamp(2rem,5vw,3.6rem);
   font-weight:900;
   letter-spacing:.04em;
   line-height:.85;
   color:#fff;
   text-transform:uppercase;
 }
