 /* Sleek slide indicator - minimal dots */
 .slide-indicator{
-  display:none; /* Hidden - we use the dot-row in nav instead */
+  display:none;
 }
 
 /* Stage */
 .stage{flex:1;overflow:hidden;position:relative;display:flex}
-.slide{position:absolute;inset:0;display:none;overflow-y:auto;padding:clamp(16px,2.5vw,32px) clamp(12px,3vw,40px)}
+.slide{position:absolute;inset:0;display:none;overflow-y:auto;padding:clamp(10px,1.6vw,24px) clamp(10px,2.2vw,28px)}
 .slide.active{display:block;animation:slideIn .35s cubic-bezier(.16,1,.3,1) both}
 @keyframes slideIn{from{opacity:0;transform:translateX(24px)}to{opacity:1;transform:translateX(0)}}
 
-.slide-inner{max-width:1000px;margin:0 auto;position:relative;z-index:1}
+.slide-inner{max-width:min(1650px,96vw);margin:0 auto;position:relative;z-index:1}
 .slide-num{
   font-family:var(--font);font-size:.4rem;letter-spacing:.3em;font-weight:900;
   color:rgba(255,255,255,.25);margin-bottom:12px;display:flex;align-items:center;gap:10px;
   animation:fadeInNum .4s ease .1s both;opacity:0;
 }
 @keyframes fadeInNum{from{opacity:0;transform:translateX(-10px)}to{opacity:1;transform:translateX(0)}}
 .slide-num::after{content:'';width:40px;height:1px;background:linear-gradient(90deg, var(--border), transparent)}
 .slide-num.hormuz-num{color:rgba(212,160,23,.55)}
 .slide-num.hormuz-num::after{background:linear-gradient(90deg, rgba(212,160,23,.4), transparent)}
 .slide-heading{
-  font-family:var(--font);font-size:clamp(1.2rem,3vw,1.9rem);font-weight:900;
+  font-family:var(--font);font-size:clamp(1.8rem,4.3vw,3.1rem);font-weight:900;
   color:var(--white);line-height:.95;margin-bottom:18px;letter-spacing:-.01em;
   animation:fadeInHeading .5s cubic-bezier(.16,1,.3,1) .15s both;opacity:0;
 }
 @keyframes fadeInHeading{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
 .slide-heading.hormuz-heading{color:var(--white);text-shadow:0 2px 20px rgba(0,0,0,.3)}
 .slide-heading.hormuz-heading::after{
   content:'';display:block;width:50px;height:3px;
   background:linear-gradient(90deg, var(--gold), transparent);margin-top:10px;border-radius:2px;
 }
 
 /* Slide layout */
-.slide-layout{display:grid;grid-template-columns:1fr;gap:18px}
-.slide-layout.has-diagram{grid-template-columns:1fr 340px;align-items:start}
+.slide-layout{display:grid;grid-template-columns:1fr;gap:24px}
+.slide-layout.has-diagram{grid-template-columns:minmax(0,1.35fr) minmax(360px,540px);align-items:start}
 
 /* Content card */
 .content-card{
   background:var(--dark2);border:1px solid var(--border);border-left:3px solid var(--white);
-  padding:clamp(12px, 2vw, 20px) clamp(14px, 2.5vw, 22px);position:relative;
+  padding:clamp(18px, 2.4vw, 30px) clamp(20px, 3vw, 34px);position:relative;
   transition:all .35s cubic-bezier(.16,1,.3,1);
   border-radius:4px;
 }
 .content-card.hormuz-card{
   border-left-color:var(--gold);background:linear-gradient(135deg, #0e0c00 0%, #0a0800 100%);
   box-shadow:0 2px 12px rgba(0,0,0,.3);
 }
 .content-card:hover{
   border-color:var(--border2);border-left-color:var(--white);
   transform:translateY(-2px);
   box-shadow:0 8px 24px rgba(0,0,0,.4);
 }
 .content-card.hormuz-card:hover{
   border-color:rgba(212,160,23,.4);border-left-color:var(--gold);
   box-shadow:0 8px 30px rgba(212,160,23,.08), 0 4px 16px rgba(0,0,0,.4);
 }
 .content-card.blurred{cursor:pointer;user-select:none}
 .content-card.blurred .content-body{filter:blur(7px);pointer-events:none;transition:filter .4s ease}
 .content-card.blurred .kf-row{filter:blur(7px);transition:filter .4s ease}
 .content-card:not(.blurred) .content-body{transition:filter .4s ease;user-select:text;cursor:text}
 .content-card:not(.blurred) .kf-row{transition:filter .4s ease}
 /* When revealed, card is not a button - only text selection */
 .content-card:not(.blurred){cursor:default;user-select:text}
 /* Text selection highlight */
 .content-card ::selection{background:rgba(212,160,23,.4);color:#fff}
