 .diagram-panel svg{width:100%;height:auto;display:block}
 .diagram-label{font-family:var(--font);font-size:.38rem;letter-spacing:.12em;font-weight:900;color:var(--muted);text-align:center}
 .hormuz-diag .diagram-label{color:rgba(212,160,23,.6)}
 
